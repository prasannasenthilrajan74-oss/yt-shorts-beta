{
    "manifest_version": 3,
    "name": "No YouTube Shorts Pro",
    "version": "1.1",
    "description": "Completely removes YouTube Shorts with toggle and analytics",
    "permissions": [
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "*://www.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://www.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "Shorts Blocker Settings"
    }
}